{
  "name": "enprove-enelyzer-datasource",
  "version": "1.0.0",
  "description": "Grafana datasource plugin for Enelyzer APIs (Energy Efficiency, Asset, CO2 Services)",
  "scripts": {
    "build": "webpack -c .config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c .config/webpack/webpack.config.ts --env development",
    "typecheck": "tsc --noEmit",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "server": "docker-compose up --build"
  },
  "author": "Enprove",
  "license": "Apache-2.0",
  "devDependencies": {
    "ajv": "^8.17.1",
    "@grafana/tsconfig": "^2.0.0",
    "@swc/core": "^1.4.2",
    "@types/lodash": "^4.14.202",
    "@types/node": "^22.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.1",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "^1.71.1",
    "sass-loader": "^14.1.1",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@grafana/data": "^11.0.0",
    "@grafana/runtime": "^11.0.0",
    "@grafana/schema": "^11.0.0",
    "@grafana/ui": "^11.0.0",
    "@emotion/css": "^11.11.2",
    "lodash": "^4.17.21",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.2"
  }
}
